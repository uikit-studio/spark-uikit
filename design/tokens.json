{
  "$schema": "https://tr.designtokens.org/format/tokens.schema.json",
  "$description": "Spark design tokens (W3C DTCG). Bold marketing kit — cream + ink + orange, grotesk display, mono labels, RTL-ready.",
  "color": {
    "$type": "color",
    "brand": {
      "50": { "$value": "#fff7ed" },
      "100": { "$value": "#ffedd5" },
      "200": { "$value": "#fed7aa" },
      "300": { "$value": "#fdba74" },
      "400": { "$value": "#fb923c" },
      "500": { "$value": "#f97316" },
      "600": { "$value": "#ea580c" },
      "700": { "$value": "#c2410c" }
    },
    "light": {
      "background": { "$value": "#faf6ee" },
      "foreground": { "$value": "#181410" },
      "card": { "$value": "#ffffff" },
      "muted": { "$value": "#f1ebe0" },
      "muted-foreground": { "$value": "#7a6f60" },
      "border": { "$value": "#e7dfd2" },
      "primary": { "$value": "#f97316" },
      "primary-foreground": { "$value": "#ffffff" },
      "ink": { "$value": "#15110c" },
      "mark": { "$value": "#fb923c" }
    },
    "dark": {
      "background": { "$value": "#14100b" },
      "foreground": { "$value": "#f7efe2" },
      "card": { "$value": "#1d1812" },
      "muted": { "$value": "#241d15" },
      "border": { "$value": "#322a1f" },
      "primary": { "$value": "#fb923c" }
    }
  },
  "font": {
    "$type": "fontFamily",
    "display": { "$value": ["Space Grotesk", "Cairo", "sans-serif"] },
    "sans": { "$value": ["Inter", "Cairo", "sans-serif"] },
    "mono": { "$value": ["JetBrains Mono", "monospace"] }
  },
  "radius": {
    "$type": "dimension",
    "DEFAULT": { "$value": "1rem" },
    "lg": { "$value": "1.5rem" }
  }
}
